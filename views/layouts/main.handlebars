    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const rutaActual = window.location.pathname;

            // Solo ejecutamos esto si estamos en la ruta correcta
            if (rutaActual === "/max/redsea" || rutaActual === "/max/redsea/") {

                // 1. Ocultar la navegación y el footer
                const elementosAOcultar = [

                    document.querySelector(".theSuperNav"),
                    document.querySelector("footer")
                ];

                elementosAOcultar.forEach(elemento => {
                    if (elemento) {
                        elemento.style.display = "none";
                    }
                });

                // 2. Inyectar CSS para forzar fondo negro
                const estiloInyectado = document.createElement('style');
                estiloInyectado.textContent = `
        /* Aplicamos el negro al body, divs, y a bodyPrincipal (ya sea clase o ID) */
        body, div, .bodyPrincipal, #bodyPrincipal {
          background-color: #000000 !important;
        }
      `;
                document.head.appendChild(estiloInyectado);
            }
        });
    </script>
